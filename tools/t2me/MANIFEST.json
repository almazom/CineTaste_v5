{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "t2me/MANIFEST.json",
  "title": "t2me Tool Manifest",
  "version": "1.0.0",

  "identity": {
    "name": "t2me",
    "verb": "send",
    "position": 6,
    "description": "Deliver message to Telegram",
    "stateless": false,
    "external": true
  },

  "contracts": {
    "input": "message-text@1.0.0",
    "output": "send-confirmation@1.0.0"
  },

  "cli": {
    "usage": "cat <FILE> | t2me send --markdown [--dry-run]",
    "flags": [
      {
        "name": "--markdown",
        "short": "-m",
        "type": "boolean",
        "default": true,
        "description": "Parse as markdown"
      },
      {
        "name": "--file",
        "short": "-f",
        "type": "string",
        "description": "Deprecated for this project; prefer stdin pipe due timeout risk"
      },
      {
        "name": "--caption",
        "short": "-c",
        "type": "string",
        "description": "Optional caption for --file mode"
      },
      {
        "name": "--dry-run",
        "type": "boolean",
        "default": false,
        "description": "Validate route/payload without sending message"
      },
      {
        "name": "--help",
        "short": "-h",
        "type": "boolean",
        "description": "Show help"
      }
    ],
    "exit_codes": {
      "0": "Success",
      "1": "General error",
      "2": "Invalid arguments",
      "3": "Network error",
      "4": "Auth error"
    }
  },

  "adapters": {
    "send_confirmation_mapper": {
      "file": "map_send_confirmation.py",
      "description": "Map raw t2me JSON output into send-confirmation contract",
      "status": "active"
    }
  },

  "files": {
    "required": [],
    "optional": ["map_send_confirmation.py"],
    "note": "External send CLI + local mapper for contract alignment"
  },

  "examples": {
    "pipe": "cat message.txt | t2me send --markdown",
    "pipe_dry_run": "cat message.txt | t2me send --markdown --dry-run"
  },

  "integration": {
    "type": "external_cli",
    "install": "pip install t2me || via TOOLS/p2me_cli",
    "auth": "t2me auth",
    "location": "/home/pets/TOOLS/p2me_cli/.venv-new/bin/t2me"
  }
}
