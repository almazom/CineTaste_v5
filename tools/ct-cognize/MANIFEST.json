{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ct-cognize/MANIFEST.json",
  "title": "ct-cognize Tool Manifest",
  "version": "1.0.0",

  "identity": {
    "name": "ct-cognize",
    "verb": "cognize",
    "position": 3,
    "description": "Human-level cognitive analysis — AI reads movie and taste files directly",
    "stateless": true
  },

  "contracts": {
    "input": "movie-schedule@1.0.0",
    "output": "analysis-result@1.0.0"
  },

  "cli": {
    "usage": "ct-cognize --input <FILE> --taste <FILE> [--agent <auto|kimi|gemini|qwen|pi>] [--output <FILE>]",
    "flags": [
      {
        "name": "--input",
        "short": "-i",
        "type": "string",
        "required": true,
        "description": "Input movie-schedule JSON file (full movie details)"
      },
      {
        "name": "--taste",
        "short": "-t",
        "type": "string",
        "required": true,
        "description": "Taste profile YAML file"
      },
      {
        "name": "--output",
        "short": "-o",
        "type": "string",
        "default": "stdout",
        "description": "Output file path"
      },
      {
        "name": "--agent",
        "short": "-a",
        "type": "string",
        "default": "auto",
        "description": "Agent: auto (fallback chain) or explicit agent name"
      },
      {
        "name": "--verbose",
        "short": "-v",
        "type": "boolean",
        "default": false,
        "description": "Verbose output"
      }
    ],
    "exit_codes": {
      "0": "Success",
      "1": "General error",
      "2": "Invalid arguments",
      "3": "All AI agents failed",
      "4": "Parse error"
    }
  },

  "design": {
    "philosophy": "Human-level perception: agent reads two files (movies + taste) and thinks about each movie, just like a person would.",
    "approach": "Write movies.json and taste.yaml to a temp workdir, launch AI agent with file-reading tools pointed at that workdir, parse JSON response."
  },

  "adapters": {
    "kimi": { "status": "active", "description": "kimi CLI (web search capable)" },
    "gemini": { "status": "active", "description": "gemini CLI (plan mode)" },
    "qwen": { "status": "active", "description": "qwen CLI (plan mode)" },
    "pi": { "status": "active", "description": "pi CLI (@file context)" }
  },

  "examples": {
    "auto": "ct-cognize --input scheduled.json --taste taste/profile.yaml",
    "explicit": "ct-cognize --input scheduled.json --taste taste/profile.yaml --agent gemini",
    "with_output": "ct-cognize --input scheduled.json --taste taste/profile.yaml --output analyzed.json"
  },

  "files": {
    "required": [
      "main.py",
      "port.py"
    ]
  }
}
