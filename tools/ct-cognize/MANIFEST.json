{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ct-cognize/MANIFEST.json",
  "title": "ct-cognize Tool Manifest",
  "version": "1.1.0",

  "identity": {
    "name": "ct-cognize",
    "verb": "cognize",
    "position": 3,
    "description": "Human-level cognitive analysis — AI reads movie and taste files directly",
    "stateless": true
  },

  "contracts": {
    "input": "movie-schedule@1.0.0",
    "output": "analysis-result@1.0.0"
  },

  "cli": {
    "usage": "ct-cognize <movie-schedule.json|-> <taste.yaml> | ct-cognize --input <FILE|-> --taste <FILE> [--agent <auto|kimi|gemini|qwen|pi> | --agents <LIST>] [--output <FILE>] [--trace-id <ID>] [--timings] [--quiet|--verbose] [--list-agents] [--version]",
    "flags": [
      {
        "name": "--input",
        "short": "-i",
        "type": "string",
        "required": false,
        "description": "Input JSON: movie-schedule contract payload file, or '-' to read from stdin"
      },
      {
        "name": "--taste",
        "short": "-t",
        "type": "string",
        "required": false,
        "description": "Taste profile YAML file"
      },
      {
        "name": "--output",
        "short": "-o",
        "type": "string",
        "default": "stdout",
        "description": "Output file path"
      },
      {
        "name": "--agent",
        "short": "-a",
        "type": "string",
        "default": "auto",
        "description": "Single agent mode: auto (parallel preflight race + runtime fallback) or explicit agent name"
      },
      {
        "name": "--agents",
        "type": "string",
        "required": false,
        "description": "Comma-separated ordered fallback chain, e.g. pi,qwen,gemini"
      },
      {
        "name": "--list-agents",
        "type": "boolean",
        "default": false,
        "description": "Print supported AI agents and exit (one name per line, shell-friendly)"
      },
      {
        "name": "--version",
        "type": "boolean",
        "default": false,
        "description": "Print CLI version and exit"
      },
      {
        "name": "--trace-id",
        "type": "string",
        "required": false,
        "description": "Attach trace ID to stderr diagnostics"
      },
      {
        "name": "--timings",
        "type": "boolean",
        "default": false,
        "description": "Print stage timings to stderr"
      },
      {
        "name": "--quiet",
        "short": "-q",
        "type": "boolean",
        "default": false,
        "description": "Suppress non-error diagnostics on stderr"
      },
      {
        "name": "--verbose",
        "short": "-v",
        "type": "boolean",
        "default": false,
        "description": "Verbose output"
      }
    ],
    "exit_codes": {
      "0": "Success",
      "1": "Internal unexpected error",
      "2": "Invalid arguments/flag values",
      "3": "Path/stdin/output filesystem error",
      "4": "AI agent availability/runtime failure",
      "5": "Input/output contract or JSON parse error"
    }
  },

  "design": {
    "philosophy": "Human-level perception: agent reads two files (movies + taste) and thinks about each movie, just like a person would.",
    "approach": "Validate movie-schedule input contract first, write movies.json and taste.yaml to a temp workdir, run preflight probes to pick ready agents (auto race or user-defined ordered chain), launch agent subprocesses in CI-safe non-interactive mode, parse JSON response, and fallback to remaining ready agents on runtime failure."
  },

  "adapters": {
    "kimi": { "status": "active", "description": "kimi CLI (web search capable)" },
    "gemini": { "status": "active", "description": "gemini CLI (cwd file-reading mode)" },
    "qwen": { "status": "active", "description": "qwen CLI (cwd file-reading mode)" },
    "pi": { "status": "active", "description": "pi CLI (@file context)" }
  },

  "examples": {
    "positional": "ct-cognize scheduled.json taste/profile.yaml",
    "stdin": "cat scheduled.json | ct-cognize --input - --taste taste/profile.yaml",
    "auto": "ct-cognize --input scheduled.json --taste taste/profile.yaml",
    "explicit": "ct-cognize --input scheduled.json --taste taste/profile.yaml --agent gemini",
    "ordered_chain": "ct-cognize --input scheduled.json --taste taste/profile.yaml --agents pi,qwen,gemini",
    "list_agents": "ct-cognize --list-agents",
    "version": "ct-cognize --version",
    "with_output": "ct-cognize --input scheduled.json --taste taste/profile.yaml --output analyzed.json",
    "alias": "ct-cognetive scheduled.json taste/profile.yaml"
  },

  "files": {
    "required": [
      "main.py",
      "port.py"
    ]
  }
}
