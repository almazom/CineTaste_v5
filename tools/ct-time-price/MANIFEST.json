{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ct-time-price/MANIFEST.json",
  "title": "ct-time-price Tool Manifest",
  "version": "1.0.0",
  "identity": {
    "name": "ct-time-price",
    "verb": "time-price",
    "position": 2,
    "description": "Fetch session times and prices for one selected movie URL",
    "stateless": true
  },
  "contracts": {
    "input": null,
    "output": "movie-showtimes@1.0.0"
  },
  "cli": {
    "usage": "ct-time-price --url <MOVIE_URL> [--date <YYYY-MM-DD>] [--source kinoteatr] [--output <FILE>] [--dry-run] [--verbose]",
    "flags": [
      {
        "name": "--url",
        "short": "-u",
        "type": "string",
        "required": true,
        "description": "Movie page URL on the supported source"
      },
      {
        "name": "--date",
        "short": "-d",
        "type": "string",
        "description": "Schedule date override (YYYY-MM-DD); defaults to local today"
      },
      {
        "name": "--source",
        "short": "-s",
        "type": "string",
        "default": "kinoteatr",
        "description": "Schedule adapter (currently only 'kinoteatr'; invalid values fail with exit code 2)"
      },
      {
        "name": "--output",
        "short": "-o",
        "type": "string",
        "default": "stdout",
        "description": "Output file path ('-' or 'stdout' writes to stdout)"
      },
      {
        "name": "--dry-run",
        "short": "-n",
        "type": "boolean",
        "default": false,
        "description": "Skip network calls and generate deterministic mock showtimes"
      },
      {
        "name": "--verbose",
        "short": "-v",
        "type": "boolean",
        "default": false,
        "description": "Verbose output"
      },
      {
        "name": "--help",
        "short": "-h",
        "type": "boolean",
        "description": "Show help"
      },
      {
        "name": "--version",
        "type": "boolean",
        "description": "Show version"
      }
    ],
    "exit_codes": {
      "0": "Success",
      "1": "Internal error",
      "2": "Invalid arguments",
      "65": "Output contract violation",
      "69": "Schedule source unavailable",
      "73": "Output/path write failure",
      "77": "Permission denied"
    }
  },
  "adapters": {
    "kinoteatr": {
      "file": "../ct-schedule/adapter_showtimes.py",
      "description": "kinoteatr.ru movie-page schedule extractor",
      "status": "active",
      "reuse": "shared with ct-schedule"
    }
  },
  "files": {
    "required": [
      "main.py",
      "port.py",
      "MANIFEST.json"
    ],
    "optional": []
  },
  "examples": {
    "today": "ct-time-price --url https://kinoteatr.ru/film/postoronniy-2/naberezhnie-chelni/",
    "date": "ct-time-price --url https://kinoteatr.ru/film/postoronniy-2/naberezhnie-chelni/ --date 2026-03-10",
    "dry_run": "ct-time-price --url https://kinoteatr.ru/film/postoronniy-2/naberezhnie-chelni/ --dry-run"
  }
}
