{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "filter-result.schema.json",
  "title": "FilterResult",
  "version": "1.0.0",
  "description": "Filtered movies matching taste threshold. Output of ct-filter, input of ct-format.",
  "type": "object",
  "required": ["filtered", "meta"],
  "properties": {
    "filtered": {
      "type": "array",
      "description": "Movies that passed filter",
      "items": {
        "type": "object",
        "required": ["movie", "relevance_score", "recommendation"],
        "properties": {
          "movie": {
            "type": "object",
            "required": ["id", "title", "url"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "original_title": { "type": "string" },
              "director": { "type": "string" },
              "actors": { "type": "array", "items": { "type": "string" } },
              "genres": { "type": "array", "items": { "type": "string" } },
              "year": { "type": ["integer", "null"] },
              "duration_min": { "type": ["integer", "null"] },
              "source": { "type": "string" },
              "url": { "type": "string" },
              "showtimes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["time", "datetime_iso"],
                  "properties": {
                    "time": {
                      "type": "string",
                      "pattern": "^\\d{2}:\\d{2}$"
                    },
                    "datetime_iso": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "price": { "type": "string" },
                    "hall": { "type": "string" },
                    "booking_url": { "type": "string", "format": "uri" }
                  },
                  "additionalProperties": false
                }
              },
              "available_days": {
                "type": "array",
                "description": "List of dates (YYYY-MM-DD) when this movie is playing. Present when fetched in aggregated horizon modes such as week or month.",
                "items": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                }
              },
              "available_days_accurate": {
                "type": "array",
                "description": "Accurate available days from data-dates attribute on movie detail page (source of truth)",
                "items": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                }
              }
            }
          },
          "relevance_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "recommendation": {
            "type": "string",
            "enum": ["must_see", "recommended"]
          },
          "reasoning": { "type": "string" },
          "key_matches": {
            "type": "array",
            "items": { "type": "string" }
          },
          "red_flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rule_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "llm_delta": {
            "type": "number"
          },
          "review_required": {
            "type": "boolean"
          },
          "decision_basis": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["total_input", "matched", "thresholds"],
      "properties": {
        "total_input": { "type": "integer", "description": "Movies before filtering" },
        "matched": { "type": "integer", "description": "Movies after filtering" },
        "thresholds": {
          "type": "object",
          "properties": {
            "recommendations": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Allowed recommendation types"
            },
            "min_score": { "type": "number", "description": "Minimum score threshold" }
          }
        },
        "filtered_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
