{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "movie-schedule.schema.json",
  "title": "MovieSchedule",
  "version": "1.0.0",
  "description": "Movies enriched with showtime schedule. Output of ct-schedule, input of ct-analyze.",
  "type": "object",
  "required": ["movies", "meta"],
  "properties": {
    "movies": {
      "type": "array",
      "description": "List of movies with showtime information",
      "items": {
        "type": "object",
        "required": ["id", "title", "source", "showtimes"],
        "properties": {
          "id": { "type": "string", "description": "Unique identifier" },
          "title": { "type": "string", "description": "Russian title" },
          "original_title": { "type": "string", "description": "Original language title" },
          "director": { "type": "string", "description": "Director name" },
          "actors": { "type": "array", "items": { "type": "string" }, "description": "Cast list" },
          "genres": { "type": "array", "items": { "type": "string" }, "description": "Genre tags" },
          "year": { "type": ["integer", "null"], "description": "Release year" },
          "duration_min": { "type": ["integer", "null"], "description": "Duration in minutes" },
          "source": { "type": "string", "description": "Source identifier (e.g., kinoteatr.ru)" },
          "url": { "type": "string", "format": "uri", "description": "Source URL" },
          "raw_description": { "type": "string", "description": "Raw description text" },
          "showtimes": {
            "type": "array",
            "description": "Showtimes for requested date",
            "items": {
              "type": "object",
              "required": ["time", "datetime_iso"],
              "properties": {
                "time": {
                  "type": "string",
                  "pattern": "^\\d{2}:\\d{2}$",
                  "description": "Session local time (HH:MM)"
                },
                "datetime_iso": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Session date-time in ISO 8601"
                },
                "price": {
                  "type": "string",
                  "description": "Optional ticket price label as shown on source page"
                },
                "hall": { "type": "string", "description": "Optional hall/screen label" },
                "booking_url": { "type": "string", "format": "uri", "description": "Optional booking URL" }
              },
              "additionalProperties": false
            }
          },
          "available_days": {
            "type": "array",
            "description": "List of dates (YYYY-MM-DD) when this movie is playing. Present when fetched in week mode.",
            "items": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          },
          "available_days_accurate": {
            "type": "array",
            "description": "Accurate available days from data-dates attribute on movie detail page (source of truth)",
            "items": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["city", "date", "fetched_at", "scheduled_at", "schedule_source"],
      "properties": {
        "city": { "type": "string", "description": "City code" },
        "city_display": { "type": "string", "description": "City display name" },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Schedule date"
        },
        "source_url": { "type": "string", "format": "uri", "description": "Cinema listing URL" },
        "fetched_at": { "type": "string", "format": "date-time", "description": "Fetch timestamp" },
        "scheduled_at": {
          "type": "string",
          "format": "date-time",
          "description": "Schedule enrichment timestamp"
        },
        "schedule_source": {
          "type": "string",
          "description": "Source used for schedule extraction"
        },
        "movies_total": { "type": "integer", "minimum": 0 },
        "movies_with_showtimes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
