{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "send-confirmation.schema.json",
  "title": "SendConfirmation",
  "version": "1.0.0",
  "description": "Telegram delivery confirmation. Output of t2me.",
  "type": "object",
  "required": ["success", "meta"],
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether send succeeded"
    },
    "message_id": {
      "type": "integer",
      "description": "Telegram message ID if successful"
    },
    "error": {
      "type": "string",
      "description": "Error message if failed"
    },
    "meta": {
      "type": "object",
      "required": ["sent_at"],
      "properties": {
        "sent_at": { "type": "string", "format": "date-time" },
        "target": { "type": "string", "description": "Telegram target" },
        "char_count": { "type": "integer", "description": "Message length" },
        "dry_run": { "type": "boolean", "description": "Whether send was validated in dry-run mode" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "success": { "const": true },
          "meta": {
            "type": "object",
            "properties": { "dry_run": { "const": false } },
            "required": ["dry_run"]
          }
        },
        "required": ["success", "meta"]
      },
      "then": { "required": ["message_id"] }
    },
    {
      "if": {
        "properties": { "success": { "const": false } },
        "required": ["success"]
      },
      "then": { "required": ["error"] }
    }
  ]
}
