{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "movie-showtimes.schema.json",
  "title": "MovieShowtimes",
  "version": "1.0.0",
  "description": "Showtimes for one selected movie URL on one selected date.",
  "type": "object",
  "required": ["movie_url", "date", "showtimes", "meta"],
  "properties": {
    "movie_url": {
      "type": "string",
      "format": "uri",
      "description": "Source movie page URL"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Requested schedule date"
    },
    "showtimes": {
      "type": "array",
      "description": "Showtimes for the selected movie and date",
      "items": {
        "type": "object",
        "required": ["time", "datetime_iso"],
        "properties": {
          "time": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "description": "Session local time (HH:MM)"
          },
          "datetime_iso": {
            "type": "string",
            "format": "date-time",
            "description": "Session date-time in ISO 8601"
          },
          "price": {
            "type": "string",
            "description": "Optional ticket price label as shown on source page"
          },
          "hall": {
            "type": "string",
            "description": "Optional hall/screen label"
          },
          "booking_url": {
            "type": "string",
            "format": "uri",
            "description": "Optional booking URL"
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["source", "fetched_at", "showtimes_count", "dry_run"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Source used for schedule extraction"
        },
        "fetched_at": {
          "type": "string",
          "format": "date-time",
          "description": "Fetch timestamp"
        },
        "showtimes_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of emitted showtimes"
        },
        "dry_run": {
          "type": "boolean",
          "description": "Whether dry-run mode generated deterministic mock showtimes"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
