{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "analysis-result.schema.json",
  "title": "AnalysisResult",
  "version": "1.0.0",
  "description": "AI-analyzed movies with taste relevance. Output of ct-analyze, input of ct-filter.",
  "type": "object",
  "required": ["analyzed", "meta"],
  "properties": {
    "analyzed": {
      "type": "array",
      "description": "Movies with analysis",
      "items": {
        "type": "object",
        "required": ["movie", "relevance_score", "recommendation"],
        "properties": {
          "movie": {
            "type": "object",
            "description": "Original movie data",
            "required": ["id", "title"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "original_title": { "type": "string" },
              "director": { "type": "string" },
              "actors": { "type": "array", "items": { "type": "string" } },
              "genres": { "type": "array", "items": { "type": "string" } },
              "year": { "type": ["integer", "null"] },
              "duration_min": { "type": ["integer", "null"] },
              "source": { "type": "string" },
              "url": { "type": "string" },
              "showtimes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["time", "datetime_iso"],
                  "properties": {
                    "time": {
                      "type": "string",
                      "pattern": "^\\d{2}:\\d{2}$"
                    },
                    "datetime_iso": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "price": { "type": "string" },
                    "hall": { "type": "string" },
                    "booking_url": { "type": "string", "format": "uri" }
                  },
                  "additionalProperties": false
                }
              },
              "available_days": {
                "type": "array",
                "description": "List of dates (YYYY-MM-DD) when this movie is playing. Present when fetched in aggregated horizon modes such as week or month.",
                "items": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                }
              },
              "available_days_accurate": {
                "type": "array",
                "description": "Accurate available days from data-dates attribute on movie detail page (source of truth)",
                "items": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                }
              }
            }
          },
          "relevance_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Taste match percentage (0-100)"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "AI confidence level (0-1)"
          },
          "recommendation": {
            "type": "string",
            "enum": ["must_see", "recommended", "maybe", "skip"],
            "description": "Recommendation category"
          },
          "reasoning": {
            "type": "string",
            "description": "Why this score was given"
          },
          "key_matches": {
            "type": "array",
            "items": { "type": "string" },
            "description": "What matched in taste profile"
          },
          "red_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "What didn't match"
          },
          "rule_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Deterministic rules-first baseline score before bounded LLM refinement"
          },
          "llm_delta": {
            "type": "number",
            "description": "Bounded LLM score adjustment applied on top of rule_score"
          },
          "review_required": {
            "type": "boolean",
            "description": "True when the movie scored well enough to inspect manually due to low confidence or rule/LLM tension"
          },
          "decision_basis": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Compact decision trail explaining the deterministic and LLM quality gates that shaped the final verdict"
          }
        },
        "additionalProperties": false
      }
    },
    "meta": {
      "type": "object",
      "required": ["analyzer", "analyzed_at"],
      "properties": {
        "analyzer": { "type": "string", "description": "AI agent used" },
        "analyzed_at": { "type": "string", "format": "date-time" },
        "taste_profile": { "type": "string", "description": "Taste profile version" },
        "agent": { "type": "string", "description": "Agent name (kimi, pi, dry_run)" },
        "web_search_used": { "type": "boolean", "description": "Whether web search was used" },
        "quality_policy": { "type": "string", "description": "Rules/merge policy label used for this analysis run" },
        "review_required_count": { "type": "integer", "minimum": 0, "description": "How many analyzed items were flagged for manual review due to low confidence or rule tension" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
