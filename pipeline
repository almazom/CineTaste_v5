#!/bin/bash
# CineTaste v5 — SSOT-driven pipeline orchestrator

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

PROTOCOL_FILE="$ROOT/PROTOCOL.json"
FLOW_FILE="$ROOT/flows/latest/FLOW.md"

CITY="naberezhnie-chelni"
CITY_DISPLAY="Набережные Челны"
APP_VERSION="unknown"
WHEN="now"
VERBOSE=false
DRY_RUN=false
RESEND_FILE=""
INPUT_FILE=""
TIMEOUT=600
LIST_RUNS=false
RERUN_ID=""

# Run logging
RUN_ID=""
RUN_DIR=""
RUN_LOG_FILE=""
RUN_START_TIME=""
declare -A STAGE_TIMINGS
declare -A STAGE_STATUS

MOVIE_COUNT="cached"
SCHEDULED_COUNT="cached"
SCHEDULED_WITH="cached"
ANALYZED_COUNT="cached"
FILTERED_COUNT=0
MSG_LINES=0

TMPDIR="$(mktemp -d)"
SSOT_JSON="$TMPDIR/ssot.json"
CURRENT_STEP=""
CURRENT_CMD=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

step() {
    echo -e "${BLUE}▶ $1${NC}" >&2
}

ok() {
    echo -e "${GREEN}✓ $1${NC}" >&2
}

warn() {
    echo -e "${YELLOW}⚠ $1${NC}" >&2
}

fail() {
    echo -e "${RED}✗ $1${NC}" >&2
}

progress_bar() {
    local current="$1"
    local total="$2"
    local width=30
    local filled=$(( (current * width) / total ))
    local empty=$((width - filled))
    local bar=""
    local i

    for ((i=0; i<filled; i++)); do
        bar="${bar}█"
    done
    for ((i=0; i<empty; i++)); do
        bar="${bar}░"
    done

    local percent=$(( (current * 100) / total ))
    echo -e "${CYAN}[${bar}] ${percent}%${NC}" >&2
}

# ── Run Logging Functions ───────────────────────────────────────────────

init_run_logging() {
    RUN_ID="$(date +%Y-%m-%dT%H%M%SZ)"
    local run_date="$(date +%Y-%m-%d)"
    RUN_DIR="$ROOT/runs/${run_date}/${RUN_ID}"
    RUN_LOG_FILE="$RUN_DIR/run.log"

    mkdir -p "$RUN_DIR/artifacts"
    mkdir -p "$RUN_DIR/logs"

    # Start tee to capture all output
    exec > >(tee -a "$RUN_LOG_FILE") 2>&1

    RUN_START_TIME="$(date +%s)"

    # Write run.yaml header
    cat > "$RUN_DIR/run.yaml" << EOF
run_id: ${RUN_ID}
pipeline_version: ${APP_VERSION}
started_at: $(date -Iseconds)
status: running
mode: $([ "$DRY_RUN" = true ] && echo "dry-run" || echo "production")

params:
  city: ${CITY}
  city_display: ${CITY_DISPLAY}
  when: ${WHEN}
  timeout: ${TIMEOUT}
  dry_run: $([ "$DRY_RUN" = true ] && echo "true" || echo "false")

EOF
}

log_stage_start() {
    local stage="$1"
    STAGE_TIMINGS["$stage"]="$(date +%s%N)"
    echo "$(date -Iseconds) | START | $stage" >> "$RUN_DIR/logs/stages.log"
}

log_stage_complete() {
    local stage="$1"
    local status="${2:-success}"
    local end_time
    end_time="$(date +%s%N)"
    local start_time="${STAGE_TIMINGS[$stage]:-$end_time}"
    local duration_ns=$((end_time - start_time))
    local duration_ms=$((duration_ns / 1000000))

    STAGE_TIMINGS["$stage"]=$duration_ms
    STAGE_STATUS["$stage"]=$status

    echo "$(date -Iseconds) | $status | $stage | ${duration_ms}ms" >> "$RUN_DIR/logs/stages.log"
}

log_preflight() {
    echo "$@" >> "$RUN_DIR/logs/preflight.log"
}

preserve_artifact() {
    local src="$1"
    local name="$2"
    if [[ -f "$src" ]]; then
        cp "$src" "$RUN_DIR/artifacts/$name"
    fi
}

finalize_run() {
    local status="$1"
    local end_time
    end_time="$(date +%s)"
    local duration=$((end_time - RUN_START_TIME))

    # Update run.yaml
    cat >> "$RUN_DIR/run.yaml" << EOF

completed_at: $(date -Iseconds)
status: ${status}
duration_seconds: ${duration}

results:
  movies_fetched: ${MOVIE_COUNT}
  movies_scheduled: ${SCHEDULED_WITH}
  movies_analyzed: ${ANALYZED_COUNT}
  movies_matched: ${FILTERED_COUNT}
  message_lines: ${MSG_LINES}
  sent: $([ "$DRY_RUN" = true ] && echo "false" || echo "true")

stages:
EOF

    # Add stage timings
    for stage in ct-fetch ct-schedule ct-cognize ct-filter ct-format t2me; do
        local timing="${STAGE_TIMINGS[$stage]:-0}"
        local stage_status="${STAGE_STATUS[$stage]:-skipped}"
        echo "  - name: $stage" >> "$RUN_DIR/run.yaml"
        echo "    status: $stage_status" >> "$RUN_DIR/run.yaml"
        echo "    duration_ms: $timing" >> "$RUN_DIR/run.yaml"
    done

    # Create summary.json
    cat > "$RUN_DIR/summary.json" << EOF
{
  "run_id": "${RUN_ID}",
  "status": "${status}",
  "mode": $([ "$DRY_RUN" = true ] && echo '"dry-run"' || echo '"production"'),
  "started_at": "$(date -Iseconds)",
  "duration_seconds": ${duration},
  "movies": {
    "fetched": ${MOVIE_COUNT},
    "matched": ${FILTERED_COUNT}
  },
  "agent": "${COGNIZE_AGENT:-auto}",
  "artifacts": [
    "artifacts/movies.json",
    "artifacts/scheduled.json",
    "artifacts/analyzed.json",
    "artifacts/filtered.json",
    "artifacts/message.txt"
  ]
}
EOF

    # Update latest symlink
    ln -sfn "$RUN_DIR" "$ROOT/runs/latest"

    echo "" >&2
    echo -e "${CYAN}📁 Run artifacts saved to: ${RUN_DIR}${NC}" >&2
}

die() {
    local message="$1"
    local code="${2:-1}"
    fail "$message"
    exit "$code"
}

log() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo "  $1" >&2
    fi
}

cleanup() {
    if [[ -d "${TMPDIR:-}" ]]; then
        rm -rf "$TMPDIR"
    fi
}

delivery_state() {
    local confirmation_file="$1"

    [[ -f "$confirmation_file" ]] || {
        echo "missing missing"
        return 0
    }

    python3 - "$confirmation_file" <<'PY'
import json
import sys

payload = json.load(open(sys.argv[1], encoding="utf-8"))
if "success" in payload:
    meta = payload.get("meta") or {}
    success = payload.get("success") is True
    dry_run = bool(meta.get("dry_run"))
else:
    result = payload.get("result") or {}
    success = str(payload.get("status", "")).lower() == "ok"
    dry_run = bool(result.get("dry_run") or payload.get("dry_run"))
print(
    "true" if success else "false",
    "true" if dry_run else "false",
)
PY
}

preserve_failure_artifacts() {
    local exit_code="${1:-1}"
    set +e
    trap - ERR

    mkdir -p "$ROOT/logs"
    local ts
    ts="$(date +%Y%m%d_%H%M%S_%N)"
    local failed_dir="$ROOT/logs/failed_${ts}"
    mkdir -p "$failed_dir"

    if [[ -d "${TMPDIR:-}" ]]; then
        cp -a "$TMPDIR"/. "$failed_dir/" 2>/dev/null || true
    fi

    {
        echo "timestamp: $(date -Iseconds)"
        echo "step: ${CURRENT_STEP:-unknown}"
        echo "exit_code: ${exit_code}"
        echo ""
        echo "command:"
        printf '%s\n' "${CURRENT_CMD:-N/A}"
    } > "$failed_dir/failure.txt"

    local send_success="missing"
    local send_dry_run="missing"
    if [[ -f "$failed_dir/send-confirmation.json" ]]; then
        read -r send_success send_dry_run < <(delivery_state "$failed_dir/send-confirmation.json")
    elif [[ -f "$failed_dir/t2me-raw.json" ]]; then
        read -r send_success send_dry_run < <(delivery_state "$failed_dir/t2me-raw.json")
    fi

    {
        echo "# CineTaste Recovery"
        echo
        echo "Failed step: \`${CURRENT_STEP:-unknown}\`"
        echo "Exit code: \`${exit_code}\`"
        echo
        echo "Artifacts preserved in:"
        echo "\`${failed_dir}\`"
        echo
        echo "Recovery paths:"

        local recovery_index=1
        if [[ -f "$failed_dir/analyzed.json" ]]; then
            echo "${recovery_index}. Retry from analyzed artifact:"
            echo "   \`./run --input ${failed_dir}/analyzed.json\`"
            recovery_index=$((recovery_index + 1))
        fi

        if [[ -f "$failed_dir/message.txt" ]]; then
            if [[ "$send_success" == "true" && "$send_dry_run" != "true" ]]; then
                echo "${recovery_index}. Do not auto-resend the preserved message:"
                echo "   Live delivery may already have succeeded; inspect \`${failed_dir}/send-confirmation.json\` and \`logs/sends.log\` first."
                recovery_index=$((recovery_index + 1))
            else
                local resend_flags=""
                if [[ "$DRY_RUN" == "true" || "$send_dry_run" == "true" ]]; then
                    resend_flags="--dry-run "
                fi
                echo "${recovery_index}. Reuse the preserved message file:"
                echo "   \`./run ${resend_flags}--resend ${failed_dir}/message.txt\`"
                recovery_index=$((recovery_index + 1))
            fi
        fi

        if [[ "$recovery_index" -eq 1 ]]; then
            echo "1. Inspect \`${failed_dir}/failure.txt\` and rerun manually from the last good artifact."
        fi
    } > "$failed_dir/RECOVER.md"

    echo "$(date -Iseconds) | step=${CURRENT_STEP:-unknown} | exit=${exit_code} | artifacts=${failed_dir}" >> "$ROOT/logs/errors.log"
    fail "Pipeline failed at ${CURRENT_STEP:-unknown}"
    fail "Artifacts preserved at ${failed_dir}"
    exit "$exit_code"
}

on_error() {
    local exit_code=$?
    
    # Finalize run logging on failure
    if [[ -n "$RUN_DIR" ]]; then
        finalize_run "failed"
    fi
    
    preserve_failure_artifacts "$exit_code"
}

trap cleanup EXIT
trap on_error ERR

usage() {
    cat << EOF
Usage: ./run [OPTIONS]

CineTaste v5 — Cinema recommendations to Telegram

Options:
  --when DATE       Date filter: 'now' or YYYY-MM-DD (default: now)
  --week            Fetch movies for the next 7 days (shorthand for --when week)
  --input FILE      Skip fetch/analyze, use cached analysis-result JSON
  --resend FILE     Resend existing message file
  --dry-run, -n     Execute full pipeline but skip live send (uses t2me --dry-run)
  --timeout SEC     Timeout for entire pipeline in seconds (default: 720)
  --list            List recent runs with status and results
  --rerun ID        Rerun a previous run (uses same parameters)
  --verbose, -v     Show details
  --version         Show version
  --help, -h        Show help

Examples:
  ./run                           # Full production pipeline
  ./run --week                    # Fetch and analyze movies for the week
  ./run --dry-run                 # Dry-run (no Telegram send)
  ./run --list                    # Show recent runs
  ./run --rerun 2026-03-10T065504Z  # Rerun specific run
EOF
    exit 0
}

list_runs() {
    local runs_dir="$ROOT/runs"
    
    if [[ ! -d "$runs_dir" ]]; then
        echo "No runs found. Execute ./run first."
        exit 0
    fi

    echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  Recent Pipeline Runs${NC}"
    echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}"
    echo ""
    printf "%-24s  %-10s  %-10s  %-10s  %-8s  %s\n" "RUN ID" "STATUS" "MODE" "MOVIES" "AGENT" "DURATION"
    echo "─────────────────────────────────────────────────────────────────────────"

    # Find all summary.json files, sorted by modification time (newest first)
    find "$runs_dir" -name "summary.json" -type f -printf '%T@ %p\n' 2>/dev/null | \
        sort -rn | \
        head -20 | \
        while read -r timestamp summary_file; do
            if [[ -f "$summary_file" ]]; then
                local run_id status mode duration movies_fetched movies_matched agent
                run_id="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['run_id'])" "$summary_file" 2>/dev/null || echo "unknown")"
                status="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['status'])" "$summary_file" 2>/dev/null || echo "unknown")"
                mode="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['mode'])" "$summary_file" 2>/dev/null || echo "unknown")"
                duration="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['duration_seconds'])" "$summary_file" 2>/dev/null || echo "0")"
                movies_fetched="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['movies']['fetched'])" "$summary_file" 2>/dev/null || echo "0")"
                movies_matched="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['movies']['matched'])" "$summary_file" 2>/dev/null || echo "0")"
                agent="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['agent'])" "$summary_file" 2>/dev/null || echo "-")"

                local status_color="$GREEN"
                [[ "$status" == "failed" ]] && status_color="$RED"
                [[ "$status" == "running" ]] && status_color="$YELLOW"

                printf "%-24s  ${status_color}%-10s${NC}  %-10s  %-10s  %-8s  %ss\n" \
                    "$run_id" "$status" "$mode" "${movies_fetched}→${movies_matched}" "$agent" "$duration"
            fi
        done

    echo ""
    exit 0
}

print_version() {
    echo "CineTaste pipeline ${APP_VERSION}"
    exit 0
}

load_protocol_defaults() {
    mapfile -t defaults < <(python3 - "$PROTOCOL_FILE" << 'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as f:
    protocol = json.load(f)

project = protocol.get("project", {})
print(project.get("city", "naberezhnie-chelni"))
print(project.get("city_display", "Набережные Челны"))
print(project.get("version", "unknown"))
PY
)

    CITY="${defaults[0]}"
    CITY_DISPLAY="${defaults[1]}"
    APP_VERSION="${defaults[2]}"
}

build_ssot_index() {
    python3 - "$PROTOCOL_FILE" "$FLOW_FILE" "$SSOT_JSON" << 'PY'
import json
import re
import sys
from pathlib import Path

protocol_path = Path(sys.argv[1])
flow_path = Path(sys.argv[2])
output_path = Path(sys.argv[3])

with protocol_path.open(encoding="utf-8") as f:
    protocol = json.load(f)

tools = protocol.get("tools", {})
flow = protocol.get("flow", {})
flow_stage_names = flow.get("stages", [])
if not flow_stage_names:
    raise SystemExit("PROTOCOL flow.stages is empty or missing")

missing_stage_tools = [name for name in flow_stage_names if name not in tools]
if missing_stage_tools:
    raise SystemExit(
        "PROTOCOL flow.stages references unknown tools: "
        f"{missing_stage_tools}"
    )

legacy_stage_tools = [
    name for name in flow_stage_names if tools.get(name, {}).get("status") == "legacy"
]
if legacy_stage_tools:
    raise SystemExit(
        "PROTOCOL flow.stages must not include legacy tools: "
        f"{legacy_stage_tools}"
    )

ordered_tools = [
    {
        "name": name,
        "position": tools[name].get("position"),
        "manifest": tools[name].get("manifest", ""),
    }
    for name in flow_stage_names
]

positions = [item["position"] for item in ordered_tools]
expected_positions = list(range(1, len(ordered_tools) + 1))
if positions != expected_positions:
    raise SystemExit(
        f"Invalid PROTOCOL positions: got {positions}, expected contiguous {expected_positions}"
    )

ordered_names = [item["name"] for item in ordered_tools]

lines = flow_path.read_text(encoding="utf-8").splitlines()
heading_step = None
heading_tool = None
blocks = []
i = 0

heading_re = re.compile(r"^##\s+Step\s+(\d+)\s+[\u2014-]\s+(.+)$")
meta_re = re.compile(r"^#\s*@([A-Za-z_]+):\s*(.+?)\s*$")

while i < len(lines):
    line = lines[i]
    heading_match = heading_re.match(line.strip())
    if heading_match:
        heading_step = int(heading_match.group(1))
        heading_tail = heading_match.group(2).strip()
        heading_tool = heading_tail.split()[0].strip("`")
        i += 1
        continue
    elif line.strip().startswith("## "):
        # Leave step context on any non-step section heading.
        heading_step = None
        heading_tool = None

    if line.strip() == "```bash":
        if heading_tool is None:
            # Non-step documentation block (for example CLI options): skip.
            i += 1
            while i < len(lines) and lines[i].strip() != "```":
                i += 1
            if i >= len(lines):
                raise SystemExit("FLOW parse error: unterminated ```bash block")
            i += 1
            continue

        i += 1
        meta = {}
        command_lines = []
        while i < len(lines) and lines[i].strip() != "```":
            raw = lines[i]
            stripped = raw.strip()
            meta_match = meta_re.match(stripped)
            if meta_match:
                key = meta_match.group(1).lower()
                value = meta_match.group(2).strip()
                meta[key] = value
            else:
                command_lines.append(raw)
            i += 1

        if i >= len(lines):
            raise SystemExit("FLOW parse error: unterminated ```bash block")

        command = "\n".join(command_lines).strip()
        if not command:
            raise SystemExit(f"FLOW parse error: empty command for step tool '{heading_tool}'")

        if "contract" not in meta:
            raise SystemExit(f"FLOW parse error: missing @contract for step tool '{heading_tool}'")
        if "output" not in meta:
            raise SystemExit(f"FLOW parse error: missing @output for step tool '{heading_tool}'")

        step_value = meta.get("step", str(heading_step))
        try:
            step_num = int(step_value)
        except ValueError:
            raise SystemExit(f"FLOW parse error: invalid @step '{step_value}' for '{heading_tool}'")

        blocks.append(
            {
                "tool": heading_tool,
                "step": step_num,
                "contract": meta["contract"],
                "output": meta["output"],
                "condition": meta.get("condition", ""),
                "command": command,
            }
        )

    i += 1

flow_order = []
for block in blocks:
    if block["tool"] not in flow_order:
        flow_order.append(block["tool"])

if flow_order != ordered_names:
    raise SystemExit(
        "FLOW/PROTOCOL mismatch: flow order "
        f"{flow_order} != protocol order {ordered_names}"
    )

for tool_name in ordered_names:
    if not any(block["tool"] == tool_name for block in blocks):
        raise SystemExit(f"FLOW parse error: no executable blocks for tool '{tool_name}'")

output_path.write_text(
    json.dumps(
        {"ordered_tools": ordered_tools, "flow_order": flow_order, "blocks": blocks},
        ensure_ascii=False,
        indent=2,
    ),
    encoding="utf-8",
)
PY
}

get_stages() {
    python3 - "$SSOT_JSON" << 'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as f:
    data = json.load(f)

for item in data.get("ordered_tools", []):
    print(item["name"])
PY
}

resolve_step_command() {
    local stage="$1"
    python3 - "$SSOT_JSON" "$stage" << 'PY'
import json
import sys

ssot_path, stage = sys.argv[1], sys.argv[2]
with open(ssot_path, encoding="utf-8") as f:
    data = json.load(f)

blocks = [b for b in data.get("blocks", []) if b.get("tool") == stage]
if not blocks:
    raise SystemExit(f"No flow blocks found for stage '{stage}'")

# Select the unconditional block (or the only block)
selected = None
for block in blocks:
    if not block.get("condition"):
        selected = block
        break

if selected is None and len(blocks) == 1:
    selected = blocks[0]

if selected is None:
    conditions = [b.get("condition", "") for b in blocks]
    raise SystemExit(
        f"No matching flow block for stage '{stage}'; "
        f"available conditions: {conditions}"
    )

print(selected["command"])
PY
}

stage_label() {
    case "$1" in
        ct-fetch) echo "Fetching movies" ;;
        ct-schedule) echo "Building showtime schedule" ;;
        ct-analyze|ct-cognize) echo "Cognitive analysis" ;;
        ct-filter) echo "Filtering by taste" ;;
        ct-format) echo "Formatting message" ;;
        t2me) echo "Sending to Telegram" ;;
        *) echo "Executing stage" ;;
    esac
}

run_stage() {
    local stage="$1"
    local current="$2"
    local total="$3"
    local label
    local cmd

    label="$(stage_label "$stage")"
    cmd="$(resolve_step_command "$stage")"
    if [[ "$stage" == "t2me" && "$DRY_RUN" == "true" ]]; then
        export T2ME_SEND_FLAGS="--dry-run"
    else
        export T2ME_SEND_FLAGS=""
    fi

    CURRENT_STEP="Step ${current}/${total}: ${stage}"
    CURRENT_CMD="$cmd"

    # Display progress bar and step info
    echo "" >&2
    progress_bar "$current" "$total"
    step "Step ${current}/${total}: ${stage} — ${label}"
    if [[ "$VERBOSE" == "true" ]]; then
        log "Command:"
        printf '%s\n' "$cmd" | sed 's/^/    /'
    fi

    # Log stage start
    log_stage_start "$stage"

    # Run with timeout
    if timeout "$TIMEOUT" bash -c "$cmd"; then
        log_stage_complete "$stage" "success"
    else
        local exit_code=$?
        if [[ $exit_code -eq 124 ]]; then
            fail "Step ${stage} timed out after ${TIMEOUT}s"
            log_stage_complete "$stage" "timeout"
        else
            log_stage_complete "$stage" "failed"
        fi
        return $exit_code
    fi
}

validate_send_confirmation_file() {
    local confirmation_file="$1"
    local send_error

    send_error="$(python3 - "$confirmation_file" "$DRY_RUN" <<'PY2'
import json
import sys

confirmation_path = sys.argv[1]
dry_run = sys.argv[2] == "true"
payload = json.load(open(confirmation_path, encoding="utf-8"))

if payload.get("success") is not True:
    print(payload.get("error") or "t2me send-confirmation indicates failure")
    raise SystemExit(1)

meta = payload.get("meta") or {}
if not dry_run and not meta.get("dry_run") and not payload.get("message_id"):
    print("t2me success payload missing message_id")
    raise SystemExit(1)
PY2
)" || true

    if [[ -n "$send_error" ]]; then
        fail "t2me send-confirmation indicates failure: $send_error"
        preserve_failure_artifacts 69
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --when)
            [[ $# -ge 2 ]] || die "--when requires a value"
            WHEN="$2"
            shift 2
            ;;
        --week)
            WHEN="week"
            shift
            ;;
        --input)
            [[ $# -ge 2 ]] || die "--input requires a value"
            INPUT_FILE="$2"
            shift 2
            ;;
        --resend)
            [[ $# -ge 2 ]] || die "--resend requires a value"
            RESEND_FILE="$2"
            shift 2
            ;;
        --dry-run|-n)
            DRY_RUN=true
            shift
            ;;
        --list)
            LIST_RUNS=true
            shift
            ;;
        --rerun)
            [[ $# -ge 2 ]] || die "--rerun requires a run ID"
            RERUN_ID="$2"
            shift 2
            ;;
        --verbose|-v)
            VERBOSE=true
            shift
            ;;
        --timeout)
            [[ $# -ge 2 ]] || die "--timeout requires a value"
            TIMEOUT="$2"
            shift 2
            ;;
        --version)
            load_protocol_defaults
            print_version
            ;;
        --)
            shift
            break
            ;;
        --help|-h)
            usage
            ;;
        *)
            die "Unknown option: $1" 64
            ;;
    esac
done

if [[ $# -gt 0 ]]; then
    die "Unexpected positional arguments: $*" 64
fi

# Handle --list
if [[ "$LIST_RUNS" == "true" ]]; then
    list_runs
fi

load_protocol_defaults
export ROOT TMPDIR CITY CITY_DISPLAY WHEN

# Initialize run logging (unless resending)
if [[ -z "$RESEND_FILE" && -z "$RERUN_ID" ]]; then
    init_run_logging
fi

if [[ -n "$RESEND_FILE" ]]; then
    resend_t2me_flags=""
    [[ -f "$RESEND_FILE" ]] || die "File not found: $RESEND_FILE" 66
    step "Resending message from $RESEND_FILE"
    cp "$RESEND_FILE" "$TMPDIR/message.txt"

    if [[ "$DRY_RUN" == "true" ]]; then
        resend_t2me_flags="--dry-run"
    fi

    CURRENT_STEP="resend"
    CURRENT_CMD="cat \"$RESEND_FILE\" | t2me send --markdown ${resend_t2me_flags} > \"$TMPDIR/t2me-raw.json\""
    eval "$CURRENT_CMD"
    python3 "$ROOT/tools/t2me/map_send_confirmation.py" \
        --input "$TMPDIR/t2me-raw.json" \
        --output "$TMPDIR/send-confirmation.json"
    validate_send_confirmation_file "$TMPDIR/send-confirmation.json"

    if [[ "$DRY_RUN" == "true" ]]; then
        ok "Dry-run confirmation validated (no live send)"
    else
        mkdir -p "$ROOT/logs"
        echo "$(date -Iseconds) - Resent: $RESEND_FILE" >> "$ROOT/logs/sends.log"
        ok "Message sent to Telegram"
    fi
    cat "$TMPDIR/send-confirmation.json"
    CURRENT_STEP=""
    CURRENT_CMD=""
    exit 0
fi

build_ssot_index
mapfile -t STAGES < <(get_stages)
TOTAL_STAGES="${#STAGES[@]}"

if [[ "$TOTAL_STAGES" -eq 0 ]]; then
    die "No stages found in SSOT index" 69
fi

if [[ -n "$INPUT_FILE" ]]; then
    [[ -f "$INPUT_FILE" ]] || die "Input file not found: $INPUT_FILE" 66
    cp "$INPUT_FILE" "$TMPDIR/analyzed.json"
    ANALYZED_COUNT="$(python3 -c "import json; print(len(json.load(open('$TMPDIR/analyzed.json'))['analyzed']))")"
    step "Using cached analysis from $INPUT_FILE"
    log "Loaded $ANALYZED_COUNT analyzed movies"
fi

for idx in "${!STAGES[@]}"; do
    stage="${STAGES[$idx]}"
    current=$((idx + 1))

    if [[ -n "$INPUT_FILE" && ( "$stage" == "ct-fetch" || "$stage" == "ct-schedule" || "$stage" == "ct-analyze" || "$stage" == "ct-cognize" ) ]]; then
        step "Step ${current}/${TOTAL_STAGES}: ${stage} — skipped (using --input)"
        continue
    fi

    run_stage "$stage" "$current" "$TOTAL_STAGES"

    case "$stage" in
        ct-fetch)
            MOVIE_COUNT="$(python3 -c "import json; print(len(json.load(open('$TMPDIR/movies.json'))['movies']))")"
            ok "Fetched $MOVIE_COUNT movies"
            preserve_artifact "$TMPDIR/movies.json" "movies.json"
            ;;
        ct-schedule)
            SCHEDULED_COUNT="$(python3 -c "import json; print(len(json.load(open('$TMPDIR/scheduled.json'))['movies']))")"
            SCHEDULED_WITH="$(python3 -c "import json; print(json.load(open('$TMPDIR/scheduled.json'))['meta'].get('movies_with_showtimes', 0))")"
            ok "Scheduled $SCHEDULED_WITH/$SCHEDULED_COUNT movies with showtimes"
            preserve_artifact "$TMPDIR/scheduled.json" "scheduled.json"
            ;;
        ct-analyze|ct-cognize)
            ANALYZED_COUNT="$(python3 -c "import json; print(len(json.load(open('$TMPDIR/analyzed.json'))['analyzed']))")"
            ok "Analyzed $ANALYZED_COUNT movies"
            preserve_artifact "$TMPDIR/analyzed.json" "analyzed.json"
            ;;
        ct-filter)
            FILTERED_COUNT="$(python3 -c "import json; d=json.load(open('$TMPDIR/filtered.json')); print(d['meta']['matched'])")"
            ok "Filtered to $FILTERED_COUNT movies"
            if [[ "$FILTERED_COUNT" -eq 0 ]]; then
                warn "No movies matched taste profile"
            fi
            preserve_artifact "$TMPDIR/filtered.json" "filtered.json"
            ;;
        ct-format)
            MSG_LINES="$(wc -l < "$TMPDIR/message.txt")"
            ok "Formatted message: $MSG_LINES lines"
            preserve_artifact "$TMPDIR/message.txt" "message.txt"
            preserve_artifact "$TMPDIR/message.json" "message.json"
            ;;
        t2me)
            validate_send_confirmation_file "$TMPDIR/send-confirmation.json"
            if [[ "$DRY_RUN" == "true" ]]; then
                ok "Dry-run confirmation validated (no live send)"
            else
                mkdir -p "$ROOT/logs"
                echo "$(date -Iseconds) - Sent: $FILTERED_COUNT movies" >> "$ROOT/logs/sends.log"
                ok "Message sent to Telegram"
            fi
            preserve_artifact "$TMPDIR/send-confirmation.json" "send-confirmation.json"
            echo "" >&2
            echo -e "${BLUE}── Message Preview ──────────────────────────────────────────${NC}" >&2
            cat "$TMPDIR/message.txt" >&2
            echo -e "${BLUE}─────────────────────────────────────────────────────────────${NC}" >&2
            ;;
    esac

    CURRENT_STEP=""
    CURRENT_CMD=""
done

echo "" >&2
echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}" >&2
echo -e "${BLUE}  ✅ CineTaste v5 — Complete${NC}" >&2
echo -e "${BLUE}════════════════════════════════════════════════════════════════${NC}" >&2
echo "" >&2
echo "  📊 Summary:" >&2
echo "     • Movies fetched:    ${MOVIE_COUNT}" >&2
echo "     • With schedule:     ${SCHEDULED_WITH}/${SCHEDULED_COUNT}" >&2
echo "     • Movies analyzed:   ${ANALYZED_COUNT}" >&2
echo "     • Movies matched:    ${FILTERED_COUNT}" >&2
if [[ "$DRY_RUN" == "true" ]]; then
    echo "     • Destination:       Telegram (dry-run)" >&2
else
    echo "     • Destination:       Telegram" >&2
fi
echo "" >&2
echo "" >&2

# Finalize run logging
finalize_run "success"
