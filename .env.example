# CineTaste v5 — Environment Variables
# Copy to .env and customize as needed

# ── Agent Timeouts (seconds) ────────────────────────────────────────────
# Preflight check timeout per agent (default: 45)
CT_COGNIZE_PREFLIGHT_TIMEOUT=45

# Runtime analysis timeout per agent (default: 600)
CT_COGNIZE_RUNTIME_TIMEOUT=600

# ── Pipeline Configuration ──────────────────────────────────────────────
# Total pipeline timeout in seconds (default: 720 = 12 min)
CT_PIPELINE_TIMEOUT=720

# ── Agent Selection ─────────────────────────────────────────────────────
# Default agent mode: auto, pi, qwen, gemini, kimi, claude
CT_COGNIZE_AGENT=auto

# Ordered fallback chain (comma-separated, overrides CT_COGNIZE_AGENT)
# Example: CT_COGNIZE_AGENTS=pi,qwen,claude
CT_COGNIZE_AGENTS=

# ── Telegram Configuration ──────────────────────────────────────────────
# Required for t2me send command
T2ME_BOT_TOKEN=
T2ME_CHAT_ID=

# ── API Keys (for AI agents) ────────────────────────────────────────────
# Set according to your agent provider requirements
# KIMI_API_KEY=
# GEMINI_API_KEY=
# QWEN_API_KEY=
# CLAUDE_API_KEY=
