{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "PROTOCOL.json",
  "title": "CineTaste v5 System Protocol",
  "version": "5.4.0",
  "description": "Single source of truth for system topology: contracts, tools, data flow",

  "project": {
    "name": "CineTaste",
    "version": "5.4.0",
    "purpose": "AI-powered cinema recommendations delivered to Telegram",
    "paradigm": "contract-first, markdown-driven orchestration",
    "city": "naberezhnie-chelni",
    "city_display": "Набережные Челны"
  },

  "philosophy": {
    "core_values": [
      "Simple > Easy (artifact simplicity, not authoring convenience)",
      "Uncomplect (one responsibility per tool)",
      "Data > Logic (declarative over imperative)",
      "Contract-first (schema before code)",
      "Stateless tools (pure functions, effects at boundaries)"
    ],
    "anti_patterns": [
      "Premature abstraction",
      "Shared mutable state",
      "Implicit dependencies",
      "Magic numbers/strings",
      "Deep nesting (use guard clauses)"
    ]
  },

  "contracts": {
    "movie-batch": {
      "file": "contracts/movie-batch.schema.json",
      "version": "1.0.0",
      "description": "Raw movies from fetcher",
      "produced_by": ["ct-fetch"],
      "consumed_by": ["ct-schedule"]
    },
    "movie-schedule": {
      "file": "contracts/movie-schedule.schema.json",
      "version": "1.0.0",
      "description": "Movies enriched with showtime schedule",
      "produced_by": ["ct-schedule"],
      "consumed_by": ["ct-cognize", "ct-analyze"]
    },
    "movie-showtimes": {
      "file": "contracts/movie-showtimes.schema.json",
      "version": "1.0.0",
      "description": "Showtimes for one selected movie URL",
      "produced_by": ["ct-showtimes"],
      "consumed_by": []
    },
    "analysis-result": {
      "file": "contracts/analysis-result.schema.json",
      "version": "1.0.0",
      "description": "AI-analyzed movies with scores",
      "produced_by": ["ct-cognize", "ct-analyze"],
      "consumed_by": ["ct-filter"]
    },
    "filter-result": {
      "file": "contracts/filter-result.schema.json",
      "version": "1.0.0",
      "description": "Filtered movies matching taste",
      "produced_by": ["ct-filter"],
      "consumed_by": ["ct-format"]
    },
    "message-text": {
      "file": "contracts/message-text.schema.json",
      "version": "1.0.0",
      "description": "Formatted Telegram message",
      "produced_by": ["ct-format"],
      "consumed_by": ["t2me"]
    },
    "send-confirmation": {
      "file": "contracts/send-confirmation.schema.json",
      "version": "1.0.0",
      "description": "Telegram delivery confirmation",
      "produced_by": ["t2me"],
      "consumed_by": []
    }
  },

  "tools": {
    "ct-fetch": {
      "manifest": "tools/ct-fetch/MANIFEST.json",
      "verb": "fetch",
      "position": 1,
      "description": "Fetch movies from cinema source",
      "input_contract": null,
      "output_contract": "movie-batch",
      "stateless": true,
      "has_adapter": true
    },
    "ct-schedule": {
      "manifest": "tools/ct-schedule/MANIFEST.json",
      "verb": "schedule",
      "position": 2,
      "description": "Enrich movie list with showtime schedule",
      "input_contract": "movie-batch",
      "output_contract": "movie-schedule",
      "stateless": true,
      "has_adapter": true
    },
    "ct-showtimes": {
      "manifest": "tools/ct-showtimes/MANIFEST.json",
      "verb": "showtimes",
      "position": 2,
      "description": "Fetch showtimes for one selected movie URL",
      "input_contract": null,
      "output_contract": "movie-showtimes",
      "stateless": true,
      "has_adapter": true
    },
    "ct-analyze": {
      "manifest": "tools/ct-analyze/MANIFEST.json",
      "verb": "analyze",
      "position": 3,
      "description": "AI cognitive analysis against taste profile (legacy, use ct-cognize)",
      "input_contract": "movie-schedule",
      "output_contract": "analysis-result",
      "stateless": true,
      "has_adapter": true,
      "status": "legacy"
    },
    "ct-cognize": {
      "manifest": "tools/ct-cognize/MANIFEST.json",
      "verb": "cognize",
      "position": 3,
      "description": "Human-level cognitive analysis — AI reads movie and taste files directly",
      "input_contract": "movie-schedule",
      "output_contract": "analysis-result",
      "stateless": true,
      "has_adapter": true
    },
    "ct-filter": {
      "manifest": "tools/ct-filter/MANIFEST.json",
      "verb": "filter",
      "position": 4,
      "description": "Filter by recommendation threshold",
      "input_contract": "analysis-result",
      "output_contract": "filter-result",
      "stateless": true,
      "has_adapter": false
    },
    "ct-format": {
      "manifest": "tools/ct-format/MANIFEST.json",
      "verb": "format",
      "position": 5,
      "description": "Render to Telegram markdown",
      "input_contract": "filter-result",
      "output_contract": "message-text",
      "stateless": true,
      "has_adapter": true
    },
    "t2me": {
      "manifest": "tools/t2me/MANIFEST.json",
      "verb": "send",
      "position": 6,
      "description": "Deliver to Telegram",
      "input_contract": "message-text",
      "output_contract": "send-confirmation",
      "stateless": false,
      "has_adapter": false,
      "external": true
    }
  },

  "flow": {
    "current_version": "1.3.1",
    "file": "flows/latest/FLOW.md",
    "stages": ["ct-fetch", "ct-schedule", "ct-cognize", "ct-filter", "ct-format", "t2me"],
    "modes": {
      "production": {
        "description": "Full pipeline with cognitive layer, sends to Telegram",
        "flags": []
      },
      "dry_run": {
        "description": "Full pipeline with cognitive layer, validates send via t2me --dry-run",
        "flags": ["--dry-run"]
      },
      "resend": {
        "description": "Resend existing message",
        "flags": ["--resend", "<file>"]
      }
    }
  },

  "memory": {
    "index": ".MEMORY/00-index.md",
    "cards": [
      ".MEMORY/01-architecture.md",
      ".MEMORY/02-contracts.md",
      ".MEMORY/03-tools.md",
      ".MEMORY/04-taste.md",
      ".MEMORY/05-troubleshooting.md",
      ".MEMORY/06-ai-agents.md"
    ]
  },

  "testing": {
    "framework": "pytest",
    "coverage_target": 80,
    "e2e_dir": ".testrun/",
    "phase_7_5": {
      "status": "complete",
      "date": "2026-03-10",
      "artifacts": {
        "golden_paths": "tests/features/golden_paths.feature",
        "boundary_cases": "tests/features/boundary_cases.feature",
        "recovery_paths": "tests/features/recovery_paths.feature",
        "sample_data": "tests/fixtures/sample_data.yaml",
        "test_plan": "tests/test_plan.md",
        "coverage_analysis": "reports/testing/coverage_analysis.md"
      },
      "receipt": {
        "phase": "7.5",
        "project_type": "cli_pipeline",
        "golden_paths_count": 5,
        "boundary_cases_count": 8,
        "recovery_paths_count": 10,
        "components_covered": [
          "ct-fetch",
          "ct-schedule",
          "ct-cognize",
          "ct-filter",
          "ct-format",
          "t2me"
        ],
        "contracts_covered": [
          "movie-batch",
          "movie-schedule",
          "analysis-result",
          "filter-result",
          "message-text",
          "send-confirmation"
        ],
        "entry_points_tested": [
          "./run (CLI main)",
          "./run --dry-run",
          "./run --input <file>",
          "./run --resend <file>"
        ],
        "layer_coverage": "4-6 layers per Golden Path",
        "methodology": "Prometheus-Vassa Plamenny (Fire-Testing Architect)"
      }
    },
    "commands": {
      "unit": "pytest tests/ -v",
      "coverage": "pytest tests/ --cov=tools --cov-report=term-missing",
      "e2e": "./run",
      "e2e_features": "pytest tests/features/ -v",
      "golden_paths": "pytest tests/features/ -k 'golden' -v",
      "boundary_cases": "pytest tests/features/ -k 'boundary' -v",
      "recovery_paths": "pytest tests/features/ -k 'recovery' -v",
      "network_integration": "pytest tests/ -m network -v"
    }
  },

  "version_history": [
    {
      "version": "5.5.0",
      "date": "2026-03-10",
      "changes": [
        "Phase 7.5: Universal Integration Testing Design complete",
        "Added tests/features/golden_paths.feature (5 critical end-to-end scenarios)",
        "Added tests/features/boundary_cases.feature (8 boundary scenarios)",
        "Added tests/features/recovery_paths.feature (10 recovery scenarios)",
        "Added tests/fixtures/sample_data.yaml with test data builders",
        "Added tests/test_plan.md with testing strategy",
        "Added reports/testing/coverage_analysis.md with component/contract mapping",
        "Added tests/conftest.py with pytest-bdd fixtures and helpers",
        "Updated PROTOCOL.json with phase_7_5 receipt and expanded test commands"
      ]
    },
    {
      "version": "5.4.0",
      "date": "2026-03-03",
      "changes": [
        "Added ct-cognize: dedicated cognitive tool with file-based agent invocation",
        "ct-cognize replaces ct-analyze in pipeline (ct-analyze marked legacy)",
        "Updated flow to v1.3 with ct-cognize at position 3",
        "Added gemini and qwen CLI agents to fallback chain",
        "Added fuzzy ID matching in analysis merge to prevent Unknown titles",
        "Pipeline aborts if all AI agents fail (no silent dry_run fallback)",
        "Added detail page enrichment in ct-fetch (directors, actors via itemprop)"
      ]
    },
    {
      "version": "5.3.0",
      "date": "2026-03-03",
      "changes": [
        "Added new contract stage: ct-schedule producing movie-schedule@1.0.0",
        "Rewired pipeline chain to ct-fetch -> ct-schedule -> ct-analyze",
        "Updated ct-analyze input boundary from movie-batch to movie-schedule",
        "Added movie-schedule schema, samples, validator helper, and tool manifest"
      ]
    },
    {
      "version": "5.2.0",
      "date": "2026-03-02",
      "changes": [
        "Pipeline runtime now parses PROTOCOL.json + flows/latest/FLOW.md at execution time",
        "Added pipeline self-healing: halt/log/preserve artifacts/recovery instructions",
        "Enforced ct-analyze --agent policy (auto fallback + strict explicit agents)",
        "Enforced JSON Schema format checks (uri/date-time) in shared validator",
        "Implemented ct-fetch --source and ct-format --template strict validation",
        "Aligned ct-format output semantics to message-text JSON contract",
        "Made default test suite deterministic (network tests marked and skipped by default)",
        "Updated docs/manifests for SSOT consistency and t2me pipe guidance"
      ]
    },
    {
      "version": "5.1.0",
      "date": "2026-03-02",
      "changes": [
        "Added pytest test suite (35 tests)",
        "Added kimi→pi→dry_run agent fallback chain",
        "Fixed ct-fetch title extraction (regex-based)",
        "Added .MEMORY/06-ai-agents.md",
        "Updated contracts to allow null year/duration",
        "Added AURA.md v2.2 with testing protocol",
        "Fixed t2me path in pipeline"
      ]
    },
    {
      "version": "5.0.0",
      "date": "2026-03-02",
      "changes": "Initial v5: PROTOCOL.json as SSOT, contract-first, simplification principles"
    }
  ]
}
